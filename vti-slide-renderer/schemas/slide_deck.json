{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VTI Slide Deck",
  "type": "object",
  "required": ["deck_meta", "slides"],
  "properties": {
    "deck_meta": {
      "type": "object",
      "required": ["theme", "lang", "title"],
      "properties": {
        "theme": { "type": "string" },
        "lang":  { "type": "string" },
        "title": { "type": "string" }
      }
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["slide_number", "layout", "section_idx", "design"],
        "properties": {
          "slide_number": { "type": "integer", "minimum": 1 },
          "layout": {
            "type": "string",
            "enum": ["I","A","B","C","D","E","F","G","H","J","K","L","M"]
          },
          "section_idx": { "type": "integer", "minimum": 0 },
          "design": { "type": "object" }
        }
      }
    }
  }
}
